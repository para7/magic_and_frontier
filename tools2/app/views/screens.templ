package views

import "tools2/app/internal/webui"

templ NoticeBox(notice *webui.Notice) {
	if notice != nil && notice.Text != "" {
		<div class={ "notice " + NoticeClass(notice) }>{ notice.Text }</div>
	}
}

templ FieldErrorBox(errs map[string]string, key string) {
	if message := FieldError(errs, key); message != "" {
		<div class="field-error">{ message }</div>
	}
}

templ PageScaffold(meta webui.PageMeta, notice *webui.Notice) {
	<section class="panel">
		<div class="page-header">
			<h1>{ meta.Title }</h1>
			<p>{ meta.Description }</p>
		</div>
		{ children... }
	</section>
}

templ ItemsPage(data webui.ItemsPageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@ItemsShell(data)
		}
	}
}

templ ItemsShell(data webui.ItemsPageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="stack">
				<div class="entry-list">
					for _, entry := range data.Entries {
						<article class="entry-card">
							<header>
								<div>
									<h3 class="code">{ entry.ID }</h3>
									<p class="entry-meta">{ entry.ItemID } x{ entry.Count }</p>
								</div>
								<div class="entry-actions">
									<a class="secondary outline" role="button" href={ "/items?edit=" + entry.ID } hx-get={ "/items?edit=" + entry.ID } hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="true">Edit</a>
										<form method="post" action={ "/items/" + entry.ID + "/delete" } hx-post={ "/items/" + entry.ID + "/delete" } hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="/items">
										<button type="submit" class="danger">Delete</button>
									</form>
								</div>
							</header>
							<dl class="kv-list">
								<dt>Item ID</dt><dd class="code">{ entry.ItemID }</dd>
								<dt>Count</dt><dd>{ entry.Count }</dd>
								<dt>Updated</dt><dd>{ entry.UpdatedAt }</dd>
								<dt>Unbreakable</dt><dd>{ BoolText(entry.Unbreakable) }</dd>
							</dl>
						</article>
					}
					if len(data.Entries) == 0 {
						<article class="entry-card"><p class="entry-meta">まだアイテムはありません。</p></article>
					}
				</div>
			</section>
			<section class="entry-card">
					<form class="form-grid two" method="post" action="/items" hx-post="/items" hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="/items">
					<input type="hidden" name="id" value={ data.Form.ID }/>
					<label>
						Item ID
						<input name="itemId" value={ data.Form.ItemID }/>
						@FieldErrorBox(data.Form.FieldErrors, "itemId")
					</label>
					<label>
						Count
						<input name="count" value={ data.Form.Count }/>
						@FieldErrorBox(data.Form.FieldErrors, "count")
					</label>
					<label>
						Custom Name
						<input name="customName" value={ data.Form.CustomName }/>
					</label>
					<label>
						Potion ID
						<input name="potionId" value={ data.Form.PotionID }/>
					</label>
					<label class="form-span-2">
						Lore
						<textarea name="lore">{ data.Form.Lore }</textarea>
					</label>
					<label class="form-span-2">
						Enchantments
						<textarea name="enchantments">{ data.Form.Enchantments }</textarea>
						<small>1行につき `namespace:enchantment level` を1件入力します。</small>
					</label>
					<label>
						CustomModelData
						<input name="customModelData" value={ data.Form.CustomModelData }/>
					</label>
					<label>
						RepairCost
						<input name="repairCost" value={ data.Form.RepairCost }/>
					</label>
					<label>
						HideFlags
						<input name="hideFlags" value={ data.Form.HideFlags }/>
					</label>
					<label>
						CustomPotionColor
						<input name="customPotionColor" value={ data.Form.CustomPotionColor }/>
					</label>
					<label class="form-span-2">
						CustomPotionEffects
						<textarea name="customPotionEffects">{ data.Form.CustomPotionEffects }</textarea>
					</label>
					<label class="form-span-2">
						AttributeModifiers
						<textarea name="attributeModifiers">{ data.Form.AttributeModifiers }</textarea>
					</label>
					<label class="form-span-2">
						Custom NBT
						<textarea name="customNbt">{ data.Form.CustomNBT }</textarea>
					</label>
					<label class="checkbox-label form-span-2">
						<input type="checkbox" name="unbreakable" checked?={ data.Form.Unbreakable }/>
						<span>Unbreakable</span>
					</label>
					@FieldErrorBox(data.Form.FieldErrors, "id")
					if data.Form.FormError != "" {
						<div class="form-span-2"><div class="field-error">{ data.Form.FormError }</div></div>
					}
					<div class="form-actions form-span-2">
						<button type="submit">{ SubmitLabel(data.Form.IsEditing) }</button>
						<a class="secondary outline" role="button" href="/items" hx-get="/items" hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="true">Reset</a>
					</div>
				</form>
			</section>
		</div>
	</div>
}

templ GrimoirePage(data webui.GrimoirePageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@GrimoireShell(data)
		}
	}
}

templ GrimoireShell(data webui.GrimoirePageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="entry-list">
				for _, entry := range data.Entries {
					<article class="entry-card">
						<header>
							<div>
								<h3>{ entry.Title }</h3>
								<p class="entry-meta code">{ entry.ID }</p>
							</div>
							<div class="entry-actions">
								<a class="secondary outline" role="button" href={ "/grimoire?edit=" + entry.ID } hx-get={ "/grimoire?edit=" + entry.ID } hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="true">Edit</a>
									<form method="post" action={ "/grimoire/" + entry.ID + "/delete" } hx-post={ "/grimoire/" + entry.ID + "/delete" } hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="/grimoire">
									<button type="submit" class="danger">Delete</button>
								</form>
							</div>
						</header>
						<dl class="kv-list">
							<dt>Cast ID</dt><dd>{ entry.CastID }</dd>
							<dt>Updated</dt><dd>{ entry.UpdatedAt }</dd>
						</dl>
						<pre>{ entry.Script }</pre>
					</article>
				}
				if len(data.Entries) == 0 {
					<article class="entry-card"><p class="entry-meta">まだ魔導書エントリはありません。</p></article>
				}
			</section>
			<section class="entry-card">
					<form class="form-grid" method="post" action="/grimoire" hx-post="/grimoire" hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="/grimoire">
					<input type="hidden" name="id" value={ data.Form.ID }/>
					<label>
						Cast ID
						<input name="castid" value={ data.Form.CastID }/>
						@FieldErrorBox(data.Form.FieldErrors, "castid")
					</label>
					<label>
						Title
						<input name="title" value={ data.Form.Title }/>
						@FieldErrorBox(data.Form.FieldErrors, "title")
					</label>
					<label>
						Description
						<textarea name="description">{ data.Form.Description }</textarea>
					</label>
					<label>
						Script
						<textarea name="script">{ data.Form.Script }</textarea>
						@FieldErrorBox(data.Form.FieldErrors, "script")
					</label>
					<label>
						Variants
						<textarea name="variantsText">{ data.Form.VariantsText }</textarea>
						<small>1行につき `cast,cost` 形式で入力します。</small>
						@FieldErrorBox(data.Form.FieldErrors, "variantsText")
					</label>
					if data.Form.FormError != "" {
						<div class="field-error">{ data.Form.FormError }</div>
					}
					<div class="form-actions">
						<button type="submit">{ SubmitLabel(data.Form.IsEditing) }</button>
						<a class="secondary outline" role="button" href="/grimoire" hx-get="/grimoire" hx-target="#feature-shell" hx-swap="outerHTML" hx-push-url="true">Reset</a>
					</div>
				</form>
			</section>
		</div>
	</div>
}

templ SkillsPage(data webui.SkillsPageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@SkillsShell(data)
		}
