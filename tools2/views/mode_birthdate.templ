package views

import "tools2/internal/form"

templ ModeBirthdateFields(state form.State) {
	<label for="birthdate">生年月日</label>
	if state.Errors.Birthdate != "" {
		<input id="birthdate" name="birthdate" type="date" value={ state.Birthdate } aria-invalid="true" required/>
		<small>{ state.Errors.Birthdate }</small>
	} else {
		<input id="birthdate" name="birthdate" type="date" value={ state.Birthdate } required/>
	}
}
