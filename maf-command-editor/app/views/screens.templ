package views

import "tools2/app/internal/webui"

templ NoticeBox(notice *webui.Notice) {
	if notice != nil && notice.Text != "" {
		<div class={ "notice " + NoticeClass(notice) }>{ notice.Text }</div>
	}
}

templ FieldErrorBox(errs map[string]string, key string) {
	if message := FieldError(errs, key); message != "" {
		<div class="field-error">{ message }</div>
	}
}

templ PageScaffold(meta webui.PageMeta, notice *webui.Notice) {
	<section class="panel">
		<div class="page-header">
			<h1>{ meta.Title }</h1>
			<p>{ meta.Description }</p>
		</div>
		{ children... }
	</section>
}

templ ReturnToField(returnTo string) {
	<input type="hidden" name="returnTo" value={ returnTo } data-return-to-input="true"/>
}

templ ListBrowser(currentURL string, newPath string, label string, searchPlaceholder string) {
	<div class="list-browser" data-list-root data-current-url={ currentURL } data-page-size="25">
		@ListToolbar(currentURL, newPath, label, searchPlaceholder)
		{ children... }
		<div class="list-toolbar-row compact list-pagination-bar">
			<p class="entry-meta list-summary" data-list-summary>Showing 0-0 of 0</p>
			<div class="list-pagination">
				<button type="button" class="secondary outline" data-list-prev>Previous</button>
				<span class="entry-meta" data-list-page-label>Page 1 / 1</span>
				<button type="button" class="secondary outline" data-list-next>Next</button>
			</div>
		</div>
	</div>
}

templ ListToolbar(currentURL string, newPath string, label string, searchPlaceholder string) {
	<div class="list-toolbar">
		<div class="list-toolbar-row">
			<div class="list-toolbar-controls">
				<label class="list-control list-search">
					Search
					<input type="search" placeholder={ searchPlaceholder } data-list-search/>
				</label>
			</div>
			<div class="form-actions">
				<a role="button" href={ WithReturnTo(newPath, currentURL) } data-return-to-link={ newPath }>{ label }</a>
			</div>
		</div>
	</div>
}

templ ListEmptyState(text string, hidden bool) {
	<article class="entry-card list-empty-state" data-list-empty hidden?={ hidden }>
		<p class="entry-meta" data-empty-default={ text } data-empty-filtered="条件に一致するエントリはありません。">{ text }</p>
	</article>
}

templ FormShellHeader(listPath string, returnTo string, title string) {
	<header>
		<div>
			<h2>{ title }</h2>
		</div>
		<div class="entry-actions">
			<a class="secondary outline" role="button" href={ BackLink(listPath, returnTo) }>Back to list</a>
		</div>
	</header>
}

templ ItemsPage(data webui.ItemsPageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@ItemsShell(data)
		}
	}
}

templ ItemsShell(data webui.ItemsPageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="stack form-span-2">
				@ListBrowser(data.Meta.CurrentURL, "/items/new", "Add Item", "ID, item ID, skill ID, custom name で検索") {
					<div class="entry-list" data-list-entries>
						for _, entry := range data.Entries {
							<article
								class="entry-card"
								data-list-item
								data-search={ SearchBlob(entry.ID, entry.ItemID, IntText(entry.Count), entry.SkillID, entry.CustomName, entry.UpdatedAt) }
								data-filters={ SkillFilterTokens(entry.SkillID) }
								data-sort-updated={ entry.UpdatedAt }
								data-sort-id={ entry.ID }
								data-sort-item_id={ entry.ItemID }
								data-sort-count={ IntText(entry.Count) }>
								<header>
									<div>
										<h3 class="code">{ entry.ID }</h3>
										<p class="entry-meta">{ entry.ItemID } x{ entry.Count }</p>
									</div>
									<div class="entry-actions">
										<a class="secondary outline" role="button" href={ WithReturnTo("/items/edit?id="+entry.ID, data.Meta.CurrentURL) } data-return-to-link={ "/items/edit?id=" + entry.ID }>Edit</a>
										<form method="post" action={ "/items/" + entry.ID + "/delete" }>
											@ReturnToField(data.Meta.CurrentURL)
											<button type="submit" class="danger">Delete</button>
										</form>
									</div>
								</header>
								<dl class="kv-list">
									<dt>Item ID</dt><dd class="code">{ entry.ItemID }</dd>
									<dt>Count</dt><dd>{ entry.Count }</dd>
									<dt>Skill</dt><dd class="code">{ entry.SkillID }</dd>
									<dt>Updated</dt><dd>{ entry.UpdatedAt }</dd>
									<dt>Unbreakable</dt><dd>{ BoolText(entry.Unbreakable) }</dd>
								</dl>
							</article>
						}
						@ListEmptyState("まだアイテムはありません。", len(data.Entries) > 0)
					</div>
				}
			</section>
		</div>
	</div>
}

templ ItemFormPage(data webui.ItemsPageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@ItemFormShell(data)
		}
	}
}

templ ItemFormShell(data webui.ItemsPageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="form-span-2">
				@FormShellHeader("/items", data.Form.ReturnTo, FormTitle("Item", data.Form.IsEditing))
				<form class="form-grid two" method="post" action={ FormAction("/items", data.Form.IsEditing) }>
					<input type="hidden" name="id" value={ data.Form.ID }/>
					@ReturnToField(data.Form.ReturnTo)
					<label>
						Item ID
						<input name="itemId" value={ data.Form.ItemID }/>
						@FieldErrorBox(data.Form.FieldErrors, "itemId")
					</label>
					<label>
						Count
						<input name="count" value={ data.Form.Count }/>
						@FieldErrorBox(data.Form.FieldErrors, "count")
					</label>
					<label>
						Skill
						<select name="skillId">
							<option value="">No skill</option>
							for _, option := range data.Form.SkillOptions {
								<option value={ option.ID } selected?={ option.ID == data.Form.SkillID }>{ option.Label }</option>
							}
						</select>
						@FieldErrorBox(data.Form.FieldErrors, "skillId")
					</label>
					<label>
						Custom Name
						<input name="customName" value={ data.Form.CustomName }/>
					</label>
					<label>
						Potion ID
						<input name="potionId" value={ data.Form.PotionID }/>
					</label>
					<label class="form-span-2">
						Lore
						<textarea name="lore">{ data.Form.Lore }</textarea>
					</label>
					<label class="form-span-2">
						Enchantments
						<textarea name="enchantments">{ data.Form.Enchantments }</textarea>
						<small>1行につき `namespace:enchantment level` を1件入力します。</small>
					</label>
					<label>
						CustomModelData
						<input name="customModelData" value={ data.Form.CustomModelData }/>
					</label>
					<label>
						RepairCost
						<input name="repairCost" value={ data.Form.RepairCost }/>
					</label>
					<label>
						HideFlags
						<input name="hideFlags" value={ data.Form.HideFlags }/>
					</label>
					<label>
						CustomPotionColor
						<input name="customPotionColor" value={ data.Form.CustomPotionColor }/>
					</label>
					<label class="form-span-2">
						CustomPotionEffects
						<textarea name="customPotionEffects">{ data.Form.CustomPotionEffects }</textarea>
					</label>
					<label class="form-span-2">
						AttributeModifiers
						<textarea name="attributeModifiers">{ data.Form.AttributeModifiers }</textarea>
					</label>
					<label class="form-span-2">
						Custom NBT
						<textarea name="customNbt">{ data.Form.CustomNBT }</textarea>
					</label>
					<label class="checkbox-label form-span-2">
						<input type="checkbox" name="unbreakable" checked?={ data.Form.Unbreakable }/>
						<span>Unbreakable</span>
					</label>
					@FieldErrorBox(data.Form.FieldErrors, "id")
					if data.Form.FormError != "" {
						<div class="form-span-2"><div class="field-error">{ data.Form.FormError }</div></div>
					}
					<div class="form-actions form-span-2">
						<button type="submit">{ SubmitLabel(data.Form.IsEditing) }</button>
						<a class="secondary outline" role="button" href={ BackLink("/items", data.Form.ReturnTo) }>Cancel</a>
					</div>
				</form>
			</section>
		</div>
	</div>
}

templ GrimoirePage(data webui.GrimoirePageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@GrimoireShell(data)
		}
	}
}

templ GrimoireShell(data webui.GrimoirePageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="form-span-2">
				@ListBrowser(data.Meta.CurrentURL, "/grimoire/new", "Add Entry", "ID, title, description, cast 情報で検索") {
					<div class="entry-list" data-list-entries>
						for _, entry := range data.Entries {
							<article
								class="entry-card"
								data-list-item
								data-search={ SearchBlob(entry.ID, entry.Title, entry.Description, IntText(entry.CastID), IntText(entry.CastTime), IntText(entry.MPCost), entry.UpdatedAt) }
								data-filters="all"
								data-sort-updated={ entry.UpdatedAt }
								data-sort-id={ entry.ID }
								data-sort-title={ entry.Title }
								data-sort-cast_id={ IntText(entry.CastID) }>
								<header>
									<div>
										<h3>{ entry.Title }</h3>
										<p class="entry-meta code">{ entry.ID }</p>
									</div>
									<div class="entry-actions">
										<a class="secondary outline" role="button" href={ WithReturnTo("/grimoire/edit?id="+entry.ID, data.Meta.CurrentURL) } data-return-to-link={ "/grimoire/edit?id=" + entry.ID }>Edit</a>
										<form method="post" action={ "/grimoire/" + entry.ID + "/delete" }>
											@ReturnToField(data.Meta.CurrentURL)
											<button type="submit" class="danger">Delete</button>
										</form>
									</div>
								</header>
								<dl class="kv-list">
									<dt>Cast ID</dt><dd>{ entry.CastID }</dd>
									<dt>Cast Time</dt><dd>{ entry.CastTime }</dd>
									<dt>MP Cost</dt><dd>{ entry.MPCost }</dd>
									<dt>Updated</dt><dd>{ entry.UpdatedAt }</dd>
								</dl>
								<pre>{ entry.Script }</pre>
							</article>
						}
						@ListEmptyState("まだ魔導書エントリはありません。", len(data.Entries) > 0)
					</div>
				}
			</section>
		</div>
	</div>
}

templ GrimoireFormPage(data webui.GrimoirePageData) {
	@Layout(data.Meta.Title, data.Meta.CurrentPath) {
		@PageScaffold(data.Meta, data.Notice) {
			@GrimoireFormShell(data)
