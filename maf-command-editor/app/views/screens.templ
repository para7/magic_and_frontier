templ GrimoireFormShell(data webui.GrimoirePageData) {
	<div id="feature-shell" class="feature-shell">
		@NoticeBox(data.Notice)
		<div class="feature-grid">
			<section class="form-span-2">
				@FormShellHeader("/grimoire", data.Form.ReturnTo, FormTitle("Grimoire Entry", data.Form.IsEditing))
				<form class="form-grid" method="post" action={ FormAction("/grimoire", data.Form.IsEditing) }>
					<input type="hidden" name="id" value={ data.Form.ID }/>
					@ReturnToField(data.Form.ReturnTo)
					<label>
						ID
						<input value={ data.Form.ID } readonly/>
						<small>Assigned by the server.</small>
					</label>
					<label>
						Cast ID
						<input name="castid" value={ data.Form.CastID } readonly/>
						<small>Assigned by the server.</small>
						@FieldErrorBox(data.Form.FieldErrors, "castid")
					</label>
					<label>
						Cast Time
						<input name="castTime" value={ data.Form.CastTime }/>
						@FieldErrorBox(data.Form.FieldErrors, "castTime")
					</label>
					<label>
						MP Cost
						<input name="mpCost" value={ data.Form.MPCost }/>
						@FieldErrorBox(data.Form.FieldErrors, "mpCost")
					</label>
					<label>
						Title
						<input name="title" value={ data.Form.Title }/>
						@FieldErrorBox(data.Form.FieldErrors, "title")
					</label>
					<label>
						Description
						<textarea name="description">{ data.Form.Description }</textarea>
					</label>
					<label class="form-span-2">
						Script
						<textarea name="script">{ data.Form.Script }</textarea>
						@FieldErrorBox(data.Form.FieldErrors, "script")
					</label>
					if data.Form.FormError != "" {
						<div class="field-error">{ data.Form.FormError }</div>
					}
					<div class="form-actions">
						<button type="submit">{ SubmitLabel(data.Form.IsEditing) }</button>
						<a class="secondary outline" role="button" href={ BackLink("/grimoire", data.Form.ReturnTo) }>Cancel</a>
					</div>
				</form>
			</section>
		</div>
	</div>
}

